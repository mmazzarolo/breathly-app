{
  "name": "breathly-app-expo",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "engines": {
    "node": "^22.13.0 || ^24.0.0 || ^26.0.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "expo",
        "expo-asset",
        "expo-build-properties",
        "expo-dev-client",
        "expo-splash-screen"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ignore-path .gitignore .",
    "lint:fix": "yarn lint --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "e2e": "maestro test .maestro/flows",
    "e2e:android": "maestro --platform=android test .maestro/flows",
    "e2e:ios": "maestro --platform=ios test .maestro/flows",
    "e2e:build:android": "expo run:android --variant release --no-bundler",
    "e2e:build:ios": "expo run:ios --configuration Release --no-bundler",
    "visual:capture": "bash scripts/visual-e2e/capture-installed.sh",
    "visual:compare": "node scripts/visual-e2e/compare.mjs",
    "validate:static": "npm run typecheck && npm run lint && npm test",
    "validate:expo": "expo install --check && expo-doctor",
    "validate:bundles": "expo export --platform all --output-dir dist/validate-export --clear",
    "validate": "npm run validate:static && npm run validate:expo",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native-stack": "^6.9.8",
    "color": "^4.2.3",
    "expo": "~56.0.15",
    "expo-asset": "~56.0.19",
    "expo-audio": "~56.0.12",
    "expo-build-properties": "~56.0.22",
    "expo-dev-client": "~56.0.22",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-keep-awake": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-navigation-bar": "~56.0.3",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "ms": "^2.1.3",
    "nativewind": "^2.0.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.19.3",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/color": "^3.0.3",
    "@types/jest": "29.5.14",
    "@types/ms": "^2.1.0",
    "@types/react": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~56.0.15",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-react": "^7.31.10",
    "eslint-plugin-react-hooks": "^4.6.0",
    "expo-doctor": "^1.20.0",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "patch-package": "^8.0.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^2.8.3",
    "prettier-plugin-tailwindcss": "^0.2.2",
    "typescript": "^6.0.3"
  }
}
